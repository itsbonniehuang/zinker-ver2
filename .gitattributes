# Handle line endings automatically for files detected as text
# and leave binary files untouched.
* text=auto

# Standardize on LF for source files
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.css text eol=lf
*.html text eol=lf
*.md text eol=lf
*.json text eol=lf
*.svg text eol=lf
